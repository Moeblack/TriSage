# DeepThink API Configuration
PORT=3000

# Agent count per round (N)
AGENT_COUNT=3

# Max Operation B repetitions (X)  
MAX_REVIEW_ROUNDS=3

# Max sub-rounds within Operation A
MAX_DEBATE_SUB_ROUNDS=3

# LLM Provider Configuration
# Supports any OpenAI-compatible API
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
# Comma-separated model list for round-robin agent assignment
# Each agent call picks the next model in sequence (globally advancing, not reset per round)
LLM_MODEL=gpt-4o-mini,claude-sonnet-4,gemini-2.5-pro

# Synthesis model (Operation K) - defaults to the first model in LLM_MODEL if not set
SYNTHESIS_MODEL=gpt-4o

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Timeouts (milliseconds)
AGENT_TIMEOUT_MS=60000
TOTAL_TIMEOUT_MS=300000

# Logging: debug, info, warn, error
LOG_LEVEL=info
